---
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  robots?: string;
  ogImage?: string;
  ogImageAlt?: string;
};

const {
  title,
  description,
  robots,
  ogImage = "/og-wattcostguide.jpg",
  ogImageAlt = "WattCostGuide appliance electricity cost calculators",
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://wattcostguide.com");
const ogImageUrl = new URL(ogImage, Astro.site ?? "https://wattcostguide.com");
const siteSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://wattcostguide.com/#organization",
      name: "WattCostGuide",
      url: "https://wattcostguide.com/",
      email: "hello@wattcostguide.com",
      contactPoint: {
        "@type": "ContactPoint",
        contactType: "editorial corrections",
        email: "hello@wattcostguide.com",
        availableLanguage: "English",
      },
    },
    {
      "@type": "WebSite",
      "@id": "https://wattcostguide.com/#website",
      url: "https://wattcostguide.com/",
      name: "WattCostGuide",
      description: "Appliance electricity cost calculators and practical home energy guides.",
      publisher: { "@id": "https://wattcostguide.com/#organization" },
      inLanguage: "en-US",
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <meta name="theme-color" content="#1f7a5b" />
    <meta property="og:site_name" content="WattCostGuide" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script type="application/ld+json" set:html={JSON.stringify(siteSchema)} />
    <script is:inline>
      let savedTheme;
      try {
        savedTheme = localStorage.getItem("theme");
      } catch {
        savedTheme = null;
      }
      const prefersDark = window.matchMedia?.("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme = savedTheme || (prefersDark ? "dark" : "light");
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <a class="brand" href="/">WattCostGuide</a>
      <div class="header-actions">
        <nav aria-label="Main navigation">
          <a href="/calculators/">Calculators</a>
          <a href="/guides/">Guides</a>
          <a href="/about/">About</a>
        </nav>
        <div class="theme-switcher" aria-label="Theme selection">
          <button type="button" data-theme-option="light" aria-pressed="false">Light</button>
          <button type="button" data-theme-option="dark" aria-pressed="false">Dark</button>
        </div>
      </div>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer class="site-footer">
      <p>WattCostGuide helps estimate appliance running costs using watts, hours, and electricity rates.</p>
      <nav aria-label="Footer navigation">
        <a href="/references/">References</a>
        <a href="/editorial-policy/">Editorial Policy</a>
        <a href="/corrections/">Corrections</a>
        <a href="/privacy-policy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href="/contact/">Contact</a>
      </nav>
    </footer>
    <script>
      const themeButtons = document.querySelectorAll<HTMLButtonElement>("[data-theme-option]");
      const applyTheme = (theme: string) => {
        document.documentElement.dataset.theme = theme;
        try {
          localStorage.setItem("theme", theme);
        } catch {
          // Theme still applies for the current page when storage is unavailable.
        }
        themeButtons.forEach((button) => {
          button.setAttribute("aria-pressed", String(button.dataset.themeOption === theme));
        });
      };

      applyTheme(document.documentElement.dataset.theme || "light");
      themeButtons.forEach((button) => {
        button.addEventListener("click", () => applyTheme(button.dataset.themeOption || "light"));
      });
    </script>
  </body>
</html>
