---
const {
  updated = "June 17, 2026",
  note = "Estimates are for general planning. Use the wattage label on your appliance and the rate from your electric bill for the most accurate result.",
} = Astro.props as {
  updated?: string;
  note?: string;
};
---

<section class="section compact-section">
  <aside class="editorial-note">
    <strong>Last updated: {updated}</strong>
    <span>{note}</span>
  </aside>
</section>
