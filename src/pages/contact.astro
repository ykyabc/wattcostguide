---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact WattCostGuide" description="Contact WattCostGuide.">
  <section class="page-header">
    <h1>Contact</h1>
    <p>Send calculator corrections, wattage suggestions, article ideas, or general questions.</p>
  </section>

  <section class="section two-column">
    <div class="article-block">
      <h2>What to include</h2>
      <p>
        If you are suggesting a correction, include the appliance name, model if available, wattage source,
        and the page URL. Clear source details make updates much easier to verify.
      </p>
    </div>
    <div class="note-panel">
      <h2>Email</h2>
      <p><a href="mailto:hello@wattcostguide.com">hello@wattcostguide.com</a></p>
      <p>We review practical corrections and appliance suggestions for future site updates.</p>
    </div>
  </section>
</BaseLayout>
