---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RelatedLinks from "../../components/RelatedLinks.astro";
import { appliances } from "../../data/appliances";
import { guides } from "../../data/guides";

const popularCalculatorSlugs = [
  "space-heater-cost-calculator",
  "air-conditioner-cost-calculator",
  "refrigerator-electricity-cost-calculator",
  "dryer-electricity-cost-calculator",
];
const popularCalculatorLinks = appliances
  .filter((appliance) => popularCalculatorSlugs.includes(appliance.slug))
  .map((appliance) => ({
    eyebrow: appliance.category,
    title: `${appliance.name} Cost Calculator`,
    description: `${appliance.wattsTypical}W typical estimate`,
    href: `/calculators/${appliance.slug}/`,
  }));
const pillarGuides = guides.filter((guide) => guide.pillar);
const supportingGuides = guides.filter((guide) => !guide.pillar);
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Electricity Cost Guides",
  itemListElement: guides.map((guide, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: guide.title,
    url: `https://wattcostguide.com/guides/${guide.slug}/`,
  })),
};
---

<BaseLayout
  title="Electricity Cost Guides for Watts, kWh and Appliances"
  description="Learn watts, kWh, cost per kWh, average appliance wattage, and energy saving basics before using appliance electricity cost calculators."
>
  <section class="page-header">
    <p class="eyebrow">Guides</p>
    <h1>Electricity Cost Guides</h1>
    <p>Simple explanations for the numbers behind appliance running costs.</p>
  </section>
  <section class="section">
    <div class="section-heading">
      <h2>Core measurement guides</h2>
      <p>Start here when you need better inputs than a generic wattage estimate.</p>
    </div>
    <div class="card-grid">
      {pillarGuides.map((guide) => (
        <a class="card" href={`/guides/${guide.slug}/`}>
          <span>{guide.category}</span>
          <strong>{guide.title}</strong>
          <small>{guide.description}</small>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>Electricity cost fundamentals</h2>
      <p>Use these supporting guides for formulas, rates, wattage ranges, and practical savings.</p>
    </div>
    <div class="card-grid">
      {supportingGuides.map((guide) => (
        <a class="card" href={`/guides/${guide.slug}/`}>
          <span>{guide.category}</span>
          <strong>{guide.title}</strong>
          <small>{guide.description}</small>
        </a>
      ))}
      <a class="card" href="/references/">
        <span>Methodology</span>
        <strong>References and Methodology</strong>
        <small>See how WattCostGuide handles formulas, wattage ranges, electricity rates, and limitations.</small>
      </a>
    </div>
  </section>

  <RelatedLinks
    title="Popular appliance calculators"
    description="After reading the basics, use a calculator to estimate a real appliance cost."
    links={popularCalculatorLinks}
  />

  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
</BaseLayout>
