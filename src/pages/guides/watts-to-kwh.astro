---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EditorialNote from "../../components/EditorialNote.astro";
import RelatedLinks from "../../components/RelatedLinks.astro";
import { appliances } from "../../data/appliances";
import { guides } from "../../data/guides";

const title = "Watts to kWh Formula for Appliance Electricity Cost";
const description = "Convert watts and hours into kWh with the simple formula kWh = watts / 1000 x hours. Use kWh to estimate appliance electricity cost from your rate.";
const relatedCalculatorSlugs = [
  "space-heater-cost-calculator",
  "air-conditioner-cost-calculator",
  "refrigerator-electricity-cost-calculator",
  "dryer-electricity-cost-calculator",
];
const relatedCalculatorLinks = appliances
  .filter((appliance) => relatedCalculatorSlugs.includes(appliance.slug))
  .map((appliance) => ({
    eyebrow: appliance.category,
    title: `${appliance.name} Cost Calculator`,
    description: `${appliance.wattsTypical}W typical estimate`,
    href: `/calculators/${appliance.slug}/`,
  }));
const relatedGuideLinks = guides
  .filter((guide) => guide.slug !== "watts-to-kwh")
  .slice(0, 3)
  .map((guide) => ({
    eyebrow: guide.category,
    title: guide.title,
    description: guide.description,
    href: `/guides/${guide.slug}/`,
  }));
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "Watts to kWh Calculator and Formula",
  description,
  author: { "@type": "Organization", name: "WattCostGuide" },
  publisher: { "@type": "Organization", name: "WattCostGuide" },
  mainEntityOfPage: "https://wattcostguide.com/guides/watts-to-kwh/",
};
---

<BaseLayout title={title} description={description}>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span>/</span>
    <a href="/guides/">Guides</a>
  </nav>

  <section class="page-header">
    <p class="eyebrow">Basics</p>
    <h1>Watts to kWh Calculator and Formula</h1>
    <p>kWh is the unit most electricity bills use to measure energy consumption.</p>
  </section>

  <EditorialNote note="This guide explains the basic watts-to-kWh conversion used by WattCostGuide calculators. Your final cost also depends on your local electricity rate." />

  <section class="section">
    <h2>Formula</h2>
    <pre><code>kWh = Watts / 1000 x Hours Used</code></pre>
    <p>A 1,500 watt appliance running for 4 hours uses 6 kWh.</p>
  </section>

  <section class="section article-block">
    <h2>What watts and kWh mean</h2>
    <p>
      Watts measure how much power an appliance draws at a moment in time. Kilowatt-hours measure how much
      energy that appliance uses over time. Your utility bill usually charges by kilowatt-hour, so converting
      watts to kWh is the bridge between an appliance label and a cost estimate.
    </p>
    <p>
      A high-wattage appliance does not always cost the most. A microwave may use more than 1,000 watts, but
      only for a few minutes. A refrigerator may use fewer watts while running, but it cycles on and off every
      day. The kWh formula lets you compare both cases using the same unit.
    </p>
  </section>

  <section class="section">
    <h2>Watts to kWh examples</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Appliance example</th>
            <th>Watts</th>
            <th>Hours used</th>
            <th>Energy used</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Space heater</td>
            <td>1,500W</td>
            <td>4 hours</td>
            <td>6 kWh</td>
          </tr>
          <tr>
            <td>Box fan</td>
            <td>60W</td>
            <td>8 hours</td>
            <td>0.48 kWh</td>
          </tr>
          <tr>
            <td>Electric dryer</td>
            <td>3,000W</td>
            <td>1 hour</td>
            <td>3 kWh</td>
          </tr>
          <tr>
            <td>Laptop</td>
            <td>65W</td>
            <td>8 hours</td>
            <td>0.52 kWh</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="section article-block">
    <h2>How to use kWh for cost</h2>
    <p>
      After you know kWh, multiply it by your electricity rate. If a heater uses 6 kWh and your rate is
      $0.18 per kWh, the estimated cost is $1.08. If your rate is $0.25 per kWh, the same use costs $1.50.
    </p>
    <pre><code>Cost = kWh x Electricity Rate</code></pre>
    <p>
      This is why WattCostGuide calculators ask for both usage time and electricity rate. The same appliance
      can have very different monthly costs in different homes or on different utility plans.
    </p>
  </section>

  <section class="section faq-list">
    <h2>Watts to kWh FAQ</h2>
    <details open>
      <summary>Is 1,000 watts the same as 1 kWh?</summary>
      <p>
        Not exactly. One thousand watts is 1 kilowatt of power. If a 1,000 watt appliance runs for 1 hour,
        it uses 1 kilowatt-hour, or 1 kWh, of energy.
      </p>
    </details>
    <details>
      <summary>Should I use 24 hours for appliances that stay plugged in?</summary>
      <p>
        Only if the appliance actually draws that wattage all day. Refrigerators, freezers, aquarium heaters,
        and similar devices cycle on and off, so active runtime is usually more useful than plugged-in time.
      </p>
    </details>
    <details>
      <summary>Where do I find appliance watts?</summary>
      <p>
        Start with the product label, owner manual, charger label, or manufacturer specifications. If you
        need a better real-world number, a plug-in energy monitor can measure actual watts and kWh.
      </p>
    </details>
  </section>

  <RelatedLinks
    title="Try the formula with real appliances"
    description="Open a calculator and adjust watts, hours, and electricity rate for a practical estimate."
    links={relatedCalculatorLinks}
  />

  <RelatedLinks
    title="Next guides to read"
    description="Continue with the cost formula, appliance wattage, and electricity rate basics."
    links={relatedGuideLinks}
  />

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</BaseLayout>
