---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { calculatorCategories } from "../../../data/categories";

const totalCalculators = calculatorCategories.reduce((count, category) => count + category.appliances.length, 0);
const popularCalculators = calculatorCategories.flatMap((category) => category.appliances.slice(0, 2)).slice(0, 8);
const calculatorCountLabel = (count: number) => `${count} calculator${count === 1 ? "" : "s"}`;
---

<BaseLayout
  title="Appliance Calculator Categories - WattCostGuide"
  description="Browse WattCostGuide appliance electricity cost calculators by category, including heating and cooling, kitchen appliances, electronics, laundry, and more."
>
  <section class="page-header">
    <p class="eyebrow">Calculator Categories</p>
    <h1>Browse Appliance Calculators by Category</h1>
    <p>
      Explore {totalCalculators} electricity cost calculators grouped by appliance type, then open the category
      that best matches what you want to estimate.
    </p>
  </section>

  <section class="section">
    <div class="card-grid">
      {calculatorCategories.map((category) => (
        <a class="card category-card" href={`/calculators/category/${category.slug}/`}>
          <span>{calculatorCountLabel(category.appliances.length)}</span>
          <strong>{category.name}</strong>
          <small>
            {category.appliances
              .slice(0, 3)
              .map((appliance) => appliance.name)
              .join(", ")}
          </small>
        </a>
      ))}
    </div>
  </section>

  <section class="section article-block">
    <h2>How categories help</h2>
    <p>
      Category pages make it easier to compare similar appliances. For example, heating and cooling devices
      often run for long periods, while kitchen appliances may use higher wattage for shorter sessions.
    </p>
    <p><a class="text-link" href="/calculators/">Search the full calculator library</a></p>
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>Popular calculators by category</h2>
      <p>Start with common appliances, then follow each calculator page to related estimates.</p>
    </div>
    <div class="card-grid">
      {popularCalculators.map((appliance) => (
        <a class="card" href={`/calculators/${appliance.slug}/`}>
          <span>{appliance.category}</span>
          <strong>{appliance.name} Cost Calculator</strong>
          <small>{appliance.wattsTypical}W typical estimate</small>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
