---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { calculatorCategories } from "../../../data/categories";

export function getStaticPaths() {
  return calculatorCategories.map((category) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const pageTitle = `${category.name} Electricity Cost Calculators - WattCostGuide`;
const description = `Browse ${category.name.toLowerCase()} electricity cost calculators and compare typical appliance wattage ranges.`;
const categoryUrl = `https://wattcostguide.com/calculators/category/${category.slug}/`;
const categoryIndex = calculatorCategories.findIndex((item) => item.slug === category.slug);
const previousCategory = categoryIndex > 0 ? calculatorCategories[categoryIndex - 1] : calculatorCategories.at(-1);
const nextCategory =
  categoryIndex < calculatorCategories.length - 1 ? calculatorCategories[categoryIndex + 1] : calculatorCategories[0];
const otherCategories = calculatorCategories
  .filter((item) => item.slug !== category.slug)
  .slice(0, 4);
const calculatorCountLabel = (count: number) => `${count} calculator${count === 1 ? "" : "s"}`;
const categoryCountLabel = (count: number) => `${count} categor${count === 1 ? "y" : "ies"}`;
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: `Which appliance in ${category.name.toLowerCase()} costs the most to run?`,
      acceptedAnswer: {
        "@type": "Answer",
        text: `The highest-cost ${category.name.toLowerCase()} appliance is usually the one with both high wattage and long runtime. Open each calculator and adjust wattage, hours, and electricity rate for a better estimate.`,
      },
    },
    {
      "@type": "Question",
      name: "Why do appliances in the same category have different costs?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Appliance cost depends on wattage, runtime, efficiency, settings, and how often the device cycles on and off.",
      },
    },
  ],
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://wattcostguide.com/" },
    { "@type": "ListItem", position: 2, name: "Calculators", item: "https://wattcostguide.com/calculators/" },
    { "@type": "ListItem", position: 3, name: category.name, item: categoryUrl },
  ],
};
---

<BaseLayout title={pageTitle} description={description}>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span>/</span>
    <a href="/calculators/">Calculators</a>
    <span>/</span>
    <a href="/calculators/categories/">Categories</a>
  </nav>

  <section class="page-header">
    <p class="eyebrow">Calculator Category</p>
    <h1>{category.name} Electricity Cost Calculators</h1>
    <p>{description}</p>
  </section>

  <section class="section">
    <div class="card-grid">
      {category.appliances.map((appliance) => (
        <a class="card" href={`/calculators/${appliance.slug}/`}>
          <span>{appliance.category}</span>
          <strong>{appliance.name} Cost Calculator</strong>
          <small>{appliance.wattsMin}W-{appliance.wattsMax}W common range</small>
        </a>
      ))}
    </div>
  </section>

  <section class="section article-block">
    <h2>How to compare these calculators</h2>
    <p>
      Start with the typical wattage shown for each appliance, then adjust the calculator to match your own
      label wattage, runtime, and electricity rate. The appliance that costs the most is usually the one with
      both high wattage and long runtime.
    </p>
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>Explore nearby categories</h2>
      <p>Use category pages to compare similar appliance groups before opening a specific calculator.</p>
    </div>
    <div class="link-panel-grid">
      <a class="link-panel" href="/calculators/">
        <span>All calculators</span>
        <strong>Browse the full calculator library</strong>
        <small>Search every appliance cost calculator</small>
      </a>
      <a class="link-panel" href="/calculators/categories/">
        <span>All categories</span>
        <strong>View every appliance category</strong>
        <small>{categoryCountLabel(calculatorCategories.length)}</small>
      </a>
      {previousCategory && previousCategory.slug !== category.slug && (
        <a class="link-panel" href={`/calculators/category/${previousCategory.slug}/`}>
          <span>Previous category</span>
          <strong>{previousCategory.name}</strong>
          <small>{calculatorCountLabel(previousCategory.appliances.length)}</small>
        </a>
      )}
      {nextCategory && nextCategory.slug !== category.slug && (
        <a class="link-panel" href={`/calculators/category/${nextCategory.slug}/`}>
          <span>Next category</span>
          <strong>{nextCategory.name}</strong>
          <small>{calculatorCountLabel(nextCategory.appliances.length)}</small>
        </a>
      )}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>Other appliance categories</h2>
      <p>Jump to another part of the home energy cost library.</p>
    </div>
    <div class="card-grid">
      {otherCategories.map((otherCategory) => (
        <a class="card category-card" href={`/calculators/category/${otherCategory.slug}/`}>
          <span>{calculatorCountLabel(otherCategory.appliances.length)}</span>
          <strong>{otherCategory.name}</strong>
          <small>
            {otherCategory.appliances
              .slice(0, 3)
              .map((appliance) => appliance.name)
              .join(", ")}
          </small>
        </a>
      ))}
    </div>
  </section>

  <section class="section faq-list">
    <h2>{category.name} calculator FAQ</h2>
    <details open>
      <summary>Which appliance in this category costs the most to run?</summary>
      <p>
        The highest-cost appliance is usually the one with both high wattage and long runtime.
        Use each calculator with your own rate and hours to compare accurately.
      </p>
    </details>
    <details>
      <summary>Can I use typical wattage instead of label wattage?</summary>
      <p>
        Typical wattage is useful for planning, but the appliance label or product manual will give a better
        estimate for your own device.
      </p>
    </details>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
